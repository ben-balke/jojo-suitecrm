{
    "name": "ben-balke/jojo-suitecrm",
    "description": "SuiteCRM integration for Jojo Render",
    "type": "library",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/ben-balke/jojo-render"
        }
    ],
    "scripts": {
        "post-install-cmd": [
            "@php bin/install-extension.php"
        ],
        "post-update-cmd": [
            "@php bin/install-extension.php"
        ]
    },
    "autoload": {
        "psr-4": {
            "JojoSuiteCRM\\": "src/"
        }
    },
    "require": {
        "php": "^8.1",
        "ben-balke/jojo-render": "dev-main"
    }
}